# ─────────────────────────────────────────────────────────────
# MICROSMART — Variables de Entorno
# Copiar este archivo a .env.local y completar los valores reales
# NUNCA subir .env.local al repositorio
# ─────────────────────────────────────────────────────────────

# ── Autenticación ────────────────────────────────────────────
# Fallback de usuario admin (si no hay usuarios en DB/JSON)
AUTH_USER=microsmart
AUTH_PASS=tu_contraseña_aqui

# Secreto para firmar tokens de sesión (mínimo 32 caracteres aleatorios)
SESSION_SECRET=clave_secreta_larga_y_aleatoria_minimo_32_chars

# ── Base URL ─────────────────────────────────────────────────
# URL pública del sitio (requerida para cron jobs en Vercel)
# Ejemplo: https://microsmart.vercel.app
NEXT_PUBLIC_BASE_URL=https://tu-dominio.vercel.app

# ── PostgreSQL (Railway) ─────────────────────────────────────
# Railway lo genera automáticamente al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@host:5432/railway

# ── Redis (Upstash) ──────────────────────────────────────────
# Requerido en producción (Vercel no tiene filesystem persistente)
# Obtener en: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu_token_aqui

# ── Cloudinary (imágenes de órdenes y logo) ──────────────────
# Obtener en: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Team Saul (servicios IMEI) ───────────────────────────────
# Obtener en: https://team-saul.com → Panel → API Key
TEAM_SAUL_API_KEY=tu_api_key_aqui
TEAM_SAUL_API_URL=https://team-saul.com/api/v2

# ── panicfull.com (análisis de diagnósticos) ─────────────────
# Cookie de sesión activa del usuario Pro
PANICFULL_COOKIES=_ga=...; _session=...

# ── Cron Jobs (Vercel) ───────────────────────────────────────
# Secreto para autenticar llamadas de cron (opcional pero recomendado)
CRON_SECRET=secreto_aleatorio_para_crons
